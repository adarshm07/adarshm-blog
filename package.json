{
  "name": "codeium-proxy-server",
  "version": "1.0.0",
  "description": "TypeScript proxy server for intercepting Codeium API calls from Windsurf",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon src/server.ts",
    "dev:build": "tsc --watch",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "postbuild": "echo 'TypeScript compilation completed successfully'",
    "build:start": "npm run build && npm start"
  },
  "dependencies": {
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.6",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/node": "^20.5.0",
    "typescript": "^5.1.6",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "rimraf": "^5.0.1"
  },
  "keywords": ["proxy", "codeium", "windsurf", "api", "typescript"],
  "author": "",
  "license": "MIT"
}